{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Backup Helper",
  "version": "0.1.0",
  "identifier": "com.backuphelper.app",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Backup Helper — Sao lưu dữ liệu",
        "width": 860,
        "height": 680,
        "minWidth": 640,
        "minHeight": 520,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
