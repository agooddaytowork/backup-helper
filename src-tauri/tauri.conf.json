{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "distDir": "../ui",
    "devPath": "../ui",
    "withGlobalTauri": true,
    "beforeBuildCommand": "",
    "beforeDevCommand": ""
  },
  "package": {
    "productName": "Backup Helper",
    "version": "0.3.0"
  },
  "tauri": {
    "allowlist": {
      "all": false
    },
    "windows": [
      {
        "label": "main",
        "title": "Backup Helper — Sao lưu dữ liệu",
        "width": 860,
        "height": 680,
        "minWidth": 640,
        "minHeight": 520,
        "resizable": true
      }
    ],
    "systemTray": {
      "iconPath": "icons/icon.ico",
      "iconAsTemplate": false
    },
    "security": {
      "csp": null
    },
    "bundle": {
      "active": true,
      "identifier": "com.backuphelper.app",
      "targets": "all",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "windows": {
        "webviewInstallMode": {
          "type": "downloadBootstrapper"
        }
      }
    }
  }
}
